    {
      "parameters": {
        "jsCode": "try {\n  const webhookNode = $('Webhook').first();\n  const config = $('LINE Config').first().json;\n  const body = webhookNode ? (webhookNode.json.body || webhookNode.json) : {};\n  const events = body.events || [];\n  const result = [];\n\n  for (const event of events) {\n    if (event.type === 'webhook_verification') {\n      return [{ json: { isVerification: true, replyToken: event.replyToken } }];\n    }\n    if (event.type !== 'message') continue;\n\n    const message = event.message || {};\n    const source = event.source || {};\n    const type = message.type || 'text';\n    const text = message.text || '';\n    const mentions = message.mention?.mentionees || message.mentions?.mentionees || [];\n    const mentionName = config.BOT_MENTION_NAME || '家庭分身';\n    const mentionTextHit = typeof text === 'string' && text.includes(mentionName);\n    const isMentioned = mentionTextHit || mentions.some((m) => m?.isSelf === true || m?.type === 'bot' || m?.mentioneeType === 'bot');\n    const messageId = message.id;\n    const userId = source.userId || '';\n    const sourceType = source.type || 'user';\n    const sourceKey = source.groupId || source.roomId || userId || 'unknown';\n    const sessionKey = `line:${sourceType}:${sourceKey}`;\n    const isMedicalCandidate = /[醫藥病痛診癌感血糖壓眠]/.test(text);\n\n    result.push({\n      json: {\n        text,\n        type,\n        messageId,\n        replyToken: event.replyToken,\n        userId,\n        displayName: '',\n        isMentioned,\n        isMedicalCandidate,\n        sourceType,\n        sourceKey,\n        sessionKey,\n      }\n    });\n  }\n\n  if (result.length === 0) {\n    return [{ json: { type: 'unknown', text: 'no message', displayName: '', sessionKey: 'line:unknown' } }];\n  }\n\n  return result;\n} catch (error) {\n  return [{ json: { error: error.message, displayName: '', sessionKey: 'line:error' } }];\n}\n"
      },
