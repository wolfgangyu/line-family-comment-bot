    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.imageBurstControl) {\n  staticData.imageBurstControl = { processingUntil: 0, cooldownByUser: {} };\n}\n\nconst state = staticData.imageBurstControl;\nconst now = Date.now();\nconst PROCESSING_MS = 70 * 1000;\nconst COOLDOWN_MS = 30 * 1000;\n\nfor (const [uid, ts] of Object.entries(state.cooldownByUser)) {\n  if (!ts || now - ts > COOLDOWN_MS) delete state.cooldownByUser[uid];\n}\n\nreturn items.map(item => {\n  const userId = item.json.userId || 'unknown';\n  const processingLocked = (state.processingUntil || 0) > now;\n  const lastUserTs = state.cooldownByUser[userId] || 0;\n  const cooldownLocked = !!lastUserTs && (now - lastUserTs <= COOLDOWN_MS);\n  let allow = false;\n  let reason = '';\n\n  if (processingLocked) reason = 'another image is currently being processed';\n  else if (cooldownLocked) reason = 'image burst within 30s';\n  else {\n    allow = true;\n    state.processingUntil = now + PROCESSING_MS;\n    state.cooldownByUser[userId] = now;\n    reason = 'passed image fence';\n  }\n\n  return { json: { ...item.json, allowImageReply: allow, imageThrottleReason: reason }, binary: item.binary, pairedItem: item.pairedItem };\n});"
      },
