    {
      "parameters": {
        "promptType": "define",
        "text": "=你是一個家庭 LINE 群組回覆判斷器。請只判斷這一句話，這個 bot 應不應該插話回覆。\n\n只有在「明確屬於沒有針對性的開放式閒聊或生活分享」時，才 allow=true。其餘情況一律 allow=false。\n\n請保守判斷，寧可少回，不要亂插話。\n\n輸出格式固定，只輸出一行 JSON，不要解釋：\n{\"allow\": true 或 false, \"reason\": \"一句很短的繁中理由\"}\n\n目前發話者：{{ $json.displayName || '對方' }}\n訊息內容：{{ $json.text }}",
        "batching": {}
      },
      "id": "intent-judge-001",
      "name": "General Chat Intent Judge",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [704, 784]
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const raw = (item.json.text || item.json.output || '').trim();\n  let parsed = null;\n  try { parsed = JSON.parse(raw); } catch (e) {\n    const match = raw.match(/\\{[\\s\\S]*\\}/);\n    if (match) {\n      try { parsed = JSON.parse(match[0]); } catch (e2) {}\n    }\n  }\n  const allow = parsed && typeof parsed.allow === 'boolean' ? parsed.allow : false;\n  const reason = parsed && typeof parsed.reason === 'string' && parsed.reason.trim() ? parsed.reason.trim() : (allow ? '一般閒聊' : '像是在對特定人說話或交辦');\n  return { json: { ...$('Prepare Normal Chat Context').first().json, intentRaw: raw, allowGeneralReply: allow, skipReason: reason } };\n});"
      },
